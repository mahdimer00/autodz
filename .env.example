# Copy this file to .env and fill in real values. Never commit .env.

# Long random string (HMAC-SHA512) used to sign anti-spam form tokens and DB
# integrity hashes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
HMAC_SECRET=

# Telegram bot that receives new part requests.
# 1) Message @BotFather on Telegram, run /newbot, copy the token it gives you.
# 2) Add the bot to your channel/group as admin, then get the chat id:
#    - For a channel: forward a channel message to @userinfobot, or use
#      https://api.telegram.org/bot<token>/getUpdates after posting in the channel.
#    - Channel chat ids usually look like -1001234567890.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Backend server port.
PORT=8787

# Origin(s) allowed to call the API. Comma-separate multiple origins, e.g.
# CLIENT_ORIGIN=https://autodz.vip,https://www.autodz.vip
CLIENT_ORIGIN=http://localhost:5173

# Set to 1 only if the server runs behind a trusted reverse proxy (nginx, etc.)
# that sets X-Forwarded-For correctly. Leave 0 otherwise.
TRUST_PROXY=0

# Basic Auth credentials for the /gestion dashboard (requests, stats, contact info).
# Leave blank to disable the admin dashboard entirely.
ADMIN_USER=
ADMIN_PASSWORD=

# Facebook Pixel ID from Meta Events Manager (Data Sources > your pixel > Settings).
# Must be prefixed with VITE_ so the frontend build can read it. Leave blank to
# disable tracking. This value is public once shipped (pixel IDs are not secret).
VITE_FB_PIXEL_ID=

# Base URL of the backend API, used by the frontend when it is deployed
# separately from the backend (e.g. frontend on Netlify, backend on a VPS).
# Leave blank for local dev (Vite's proxy handles relative /api calls).
VITE_API_BASE_URL=
